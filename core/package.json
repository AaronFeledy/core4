{
  "name": "@lando/core",
  "description": "Lando v4 core: runtime, planner, OCLIF adapter, and library API.",
  "version": "0.0.0",
  "author": "Lando Alliance",
  "license": "MIT",
  "homepage": "https://github.com/lando-community/core4",
  "repository": "lando-community/core4",
  "bugs": "https://github.com/lando-community/core4/issues",
  "type": "module",
  "private": true,
  "engines": {
    "bun": ">=1.3.14"
  },
  "bin": {
    "lando": "./bin/lando.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": { "types": "./src/index.ts", "import": "./src/index.ts" },
    "./schema": { "types": "./src/schema/index.ts", "import": "./src/schema/index.ts" },
    "./docs/components": {
      "types": "./src/docs/components/index.ts",
      "import": "./src/docs/components/index.ts"
    },
    "./docs/render": {
      "types": "./src/docs/render/index.ts",
      "import": "./src/docs/render/index.ts"
    },
    "./errors": { "types": "./src/errors/index.ts", "import": "./src/errors/index.ts" },
    "./events": { "types": "./src/lifecycle/index.ts", "import": "./src/lifecycle/index.ts" },
    "./services": { "types": "./src/services/index.ts", "import": "./src/services/index.ts" },
    "./testing": { "types": "./src/testing/index.ts", "import": "./src/testing/index.ts" },
    "./cli": { "types": "./src/cli/index.ts", "import": "./src/cli/index.ts" },
    "./cli/operations": { "types": "./src/cli/operations.ts", "import": "./src/cli/operations.ts" },
    "./oclif": { "types": "./src/cli/oclif/index.ts", "import": "./src/cli/oclif/index.ts" }
  },
  "files": ["./bin", "./dist", "!./dist/**/*.tsbuildinfo", "./src", "./oclif.manifest.json"],
  "keywords": ["lando", "lando-core", "oclif", "effect", "bun"],
  "dependencies": {
    "@lando/sdk": "workspace:*",
    "@oclif/core": "^4.11.2",
    "@oclif/plugin-help": "^6.2.48",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@oclif/test": "^4.1.18",
    "oclif": "^4.23.0"
  },
  "oclif": {
    "bin": "lando",
    "dirname": "lando",
    "commands": "./src/cli/oclif/commands",
    "plugins": ["@oclif/plugin-help"],
    "topicSeparator": " ",
    "flexibleTaxonomy": true,
    "additionalHelpFlags": ["-h"],
    "additionalVersionFlags": ["-v"],
    "topics": {
      "app": {
        "description": "Operate on the current Lando app."
      },
      "app:cache": {
        "description": "App plan, tooling graph, and command index cache."
      },
      "app:config": {
        "description": "Read/write the current app's Landofile."
      },
      "app:includes": {
        "description": "Manage the app's includes lockfile."
      },
      "apps": {
        "description": "Discover and operate across Lando apps on the host."
      },
      "meta": {
        "description": "Operate on Lando itself: config, plugins, host setup."
      },
      "meta:events": {
        "description": "Lifecycle event diagnostics."
      },
      "meta:plugin": {
        "description": "Plugin install, remove, and authoring commands."
      },
      "meta:recipes": {
        "description": "Inspect canonical recipes shipped with Lando."
      },
      "apps:scratch": {
        "description": "Short-lived scratch apps (Phase 3 Beta deliverable)."
      },
      "meta:global": {
        "description": "Manage the host-level global Lando app (Phase 3 Beta deliverable)."
      }
    },
    "hooks": {
      "init": {
        "target": "./src/cli/oclif/hooks/init.ts",
        "identifier": "initHook"
      }
    }
  },
  "scripts": {
    "build": "bun run build:manifest && bun run build:compile",
    "build:bin": "bun build ./bin/lando.ts --outdir ./dist --target bun",
    "build:manifest": "bun run ../scripts/build-oclif-manifest.ts",
    "build:compile": "bun build ./bin/lando.ts --compile --bytecode --outfile ./dist/lando --sourcemap=external && bun run ../scripts/sanitize-compiled-binary.ts ./dist/lando",
    "clean": "rm -rf dist oclif.manifest.json .tsbuildinfo",
    "test": "bun test",
    "typecheck": "tsc -b",
    "postpack": "rm -f oclif.manifest.json",
    "prepack": "bunx oclif manifest"
  }
}
