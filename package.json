{
  "name": "@lando/monorepo",
  "version": "0.0.0",
  "description": "Lando v4 monorepo: @lando/core, @lando/sdk, and bundled plugins.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/lando-community/core4",
  "repository": "lando-community/core4",
  "bugs": "https://github.com/lando-community/core4/issues",
  "workspaces": ["core", "sdk", "container-runtime", "plugins/*"],
  "engines": {
    "bun": ">=1.3.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.14",
    "mdast-util-to-markdown": "^2.1.2",
    "typescript": "^5.6.0"
  },
  "scripts": {
    "build": "bun run --filter='*' build",
    "test": "bun test",
    "test:unit": "bun --no-orphans test --path-ignore-patterns='**/*.integration.test.ts'",
    "test:changed": "bun test --changed",
    "bench:tooling-hot-path": "bun run scripts/bench-tooling-hot-path.ts",
    "typecheck": "tsc -b",
    "lint": "biome check . && bun run check:deprecations",
    "format": "biome format --write .",
    "clean": "bun run --filter='*' clean && rm -rf dist .tsbuildinfo",
    "codegen": "bun run scripts/codegen.ts",
    "codegen:check": "bun run codegen && bun run check:deprecations && bun run typecheck",
    "docs:scenario": "bun run scripts/docs-scenario.ts",
    "dev:guides": "bun run scripts/dev-guides.ts",
    "lint:guides": "bun run scripts/lint-guides.ts",
    "check:renderer-boundary": "bun run scripts/check-renderer-boundary.ts",
    "check:managed-file-boundary": "bun run scripts/check-managed-file-boundary.ts",
    "check:redaction-boundary": "bun run scripts/check-redaction-boundary.ts",
    "check:env-helper-boundary": "bun run scripts/check-env-helper-boundary.ts",
    "check:paths-boundary": "bun run scripts/check-paths-boundary.ts",
    "check:state-store-boundary": "bun run scripts/check-state-store-boundary.ts",
    "check:probe-boundary": "bun run scripts/check-probe-boundary.ts",
    "check:telemetry-inventory": "bun run scripts/check-telemetry-inventory.ts",
    "check:deprecations": "bun run scripts/check-deprecations.ts",
    "check:guide-coverage": "bun run scripts/check-guide-coverage.ts",
    "check:public-transcripts": "bun run scripts/check-public-transcripts.ts",
    "check:guide-drift": "bun run scripts/check-guide-drift.ts",
    "codegen:bootstrap-layers": "bun run scripts/build-bootstrap-layers.ts",
    "codegen:bundled-plugins": "bun run scripts/build-bundled-plugins.ts",
    "codegen:oclif-manifest": "bun run scripts/build-oclif-manifest.ts",
    "codegen:recipe-readmes": "bun run scripts/build-recipe-readmes.ts",
    "codegen:bundled-recipes": "bun run scripts/build-bundled-recipes.ts",
    "codegen:schema-snapshot": "bun run scripts/build-schema-snapshot.ts",
    "release": "bun run scripts/release.ts"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  }
}
