{
  "name": "@lando/monorepo",
  "version": "0.0.0",
  "description": "Lando v4 monorepo: @lando/core, @lando/sdk, and bundled plugins.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/lando-community/core4",
  "repository": "lando-community/core4",
  "bugs": "https://github.com/lando-community/core4/issues",
  "workspaces": ["core", "sdk", "plugins/*"],
  "engines": {
    "bun": ">=1.3.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.14",
    "typescript": "^5.6.0"
  },
  "scripts": {
    "build": "bun run --filter='*' build",
    "test": "bun test",
    "test:unit": "bun --no-orphans test --path-ignore-patterns='**/*.integration.test.ts'",
    "test:changed": "bun test --changed",
    "typecheck": "tsc -b",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "bun run --filter='*' clean && rm -rf dist .tsbuildinfo",
    "codegen": "bun run scripts/codegen.ts",
    "docs:scenario": "bun run scripts/docs-scenario.ts",
    "lint:guides": "bun run scripts/lint-guides.ts",
    "codegen:bundled-plugins": "bun run scripts/build-bundled-plugins.ts",
    "codegen:bundled-recipes": "bun run scripts/build-bundled-recipes.ts",
    "codegen:schema-snapshot": "bun run scripts/build-schema-snapshot.ts",
    "release": "bun run scripts/release.ts"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  }
}
