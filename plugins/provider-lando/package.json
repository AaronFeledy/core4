{
  "name": "@lando/provider-lando",
  "description": "Reference Lando-managed RuntimeProvider implementation.",
  "version": "0.0.0",
  "author": "Lando Alliance",
  "license": "MIT",
  "homepage": "https://github.com/lando-community/core4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lando-community/core4.git",
    "directory": "plugins/provider-lando"
  },
  "type": "module",
  "private": true,
  "engines": {
    "bun": ">=1.3.14"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "./src",
    "./dist",
    "!./dist/**/*.tsbuildinfo",
    "./plugin.yaml"
  ],
  "keywords": [
    "lando",
    "lando-plugin",
    "lando-provider"
  ],
  "lando": {
    "manifest": "./plugin.yaml"
  },
  "peerDependencies": {
    "@lando/core": "workspace:*",
    "@lando/sdk": "workspace:*"
  },
  "dependencies": {
    "@lando/container-runtime": "workspace:*",
    "effect": "^3.21.2"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist .tsbuildinfo",
    "typecheck": "tsc -b"
  }
}
