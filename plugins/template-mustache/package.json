{
  "name": "@lando/template-mustache",
  "description": "Mustache whole-file template engine for Lando v4.",
  "version": "0.0.0",
  "author": "Lando Alliance",
  "license": "MIT",
  "homepage": "https://github.com/lando-community/core4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lando-community/core4.git",
    "directory": "plugins/template-mustache"
  },
  "type": "module",
  "private": true,
  "engines": {
    "bun": ">=1.3.14"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["./src", "./dist", "!./dist/**/*.tsbuildinfo", "./plugin.yaml"],
  "keywords": ["lando", "lando-plugin", "lando-template", "mustache"],
  "lando": {
    "manifest": "./plugin.yaml"
  },
  "dependencies": {
    "@lando/sdk": "workspace:*",
    "effect": "^3.21.2",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "@types/mustache": "^4.2.6"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist .tsbuildinfo",
    "typecheck": "tsc -b"
  }
}
