{
  "name": "@lando/sdk",
  "description": "Type-only contracts for Lando v4 plugin authors: Effect Schemas, Effect Service tags, and tagged-error classes.",
  "version": "0.0.0",
  "author": "Lando Alliance",
  "license": "MIT",
  "homepage": "https://github.com/lando-community/core4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lando-community/core4.git",
    "directory": "sdk"
  },
  "type": "module",
  "private": true,
  "engines": {
    "bun": ">=1.3.14"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app/index.ts",
    "./schema": "./src/schema/index.ts",
    "./docs/components": "./src/docs/components/index.ts",
    "./errors": "./src/errors/index.ts",
    "./services": "./src/services/index.ts",
    "./events": "./src/events/index.ts",
    "./expressions": "./src/expressions/index.ts",
    "./landofile": "./src/landofile/index.ts",
    "./log-follow": "./src/log-follow/index.ts",
    "./network-trust": "./src/network-trust/index.ts",
    "./probe": "./src/probe/index.ts",
    "./renderer": "./src/renderer/index.ts",
    "./plugins": "./src/plugins/index.ts",
    "./secrets": "./src/secrets/index.ts",
    "./template": "./src/template/index.ts",
    "./tool-provisioning": "./src/tool-provisioning/index.ts",
    "./verified-stream": "./src/verified-stream/index.ts",
    "./test": "./src/test/index.ts"
  },
  "files": ["./src", "./dist", "!./dist/**/*.tsbuildinfo"],
  "keywords": ["lando", "lando-sdk", "effect"],
  "dependencies": {
    "effect": "^3.21.2",
    "semver": "^7.8.5"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist .tsbuildinfo",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1"
  }
}
