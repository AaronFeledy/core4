{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "authorityPorts": {
      "additionalProperties": false,
      "description": "Resolved HTTP and HTTPS ports included in route URL authorities.",
      "properties": {
        "http": {
          "description": "Resolved HTTP port included in the route URL authority.",
          "maximum": 65535,
          "minimum": 1,
          "title": "between(1, 65535)",
          "type": "integer"
        },
        "https": {
          "description": "Resolved HTTPS port included in the route URL authority.",
          "maximum": 65535,
          "minimum": 1,
          "title": "between(1, 65535)",
          "type": "integer"
        }
      },
      "required": [],
      "type": "object"
    },
    "endpoint": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        }
      ]
    },
    "hostname": {
      "type": "string"
    },
    "pathPrefix": {
      "type": "string"
    },
    "scheme": {
      "enum": [
        "http",
        "https",
        "both"
      ],
      "type": "string"
    },
    "service": {
      "type": "string"
    }
  },
  "required": [
    "hostname",
    "scheme",
    "service"
  ],
  "type": "object"
}
