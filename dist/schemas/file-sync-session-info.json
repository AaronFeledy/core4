{
  "$defs": {
    "DateTimeUtc": {
      "description": "a string to be decoded into a DateTime.Utc",
      "type": "string"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "app": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "user",
            "global",
            "scratch"
          ],
          "type": "string"
        },
        "root": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "root"
      ],
      "type": "object"
    },
    "detail": {
      "type": "string"
    },
    "lastUpdatedAt": {
      "$ref": "#/$defs/DateTimeUtc"
    },
    "mountKey": {
      "type": "string"
    },
    "ref": {
      "type": "string"
    },
    "service": {
      "type": "string"
    },
    "status": {
      "enum": [
        "running",
        "paused",
        "draining",
        "errored"
      ],
      "type": "string"
    }
  },
  "required": [
    "ref",
    "app",
    "service",
    "mountKey",
    "status",
    "lastUpdatedAt"
  ],
  "type": "object"
}
