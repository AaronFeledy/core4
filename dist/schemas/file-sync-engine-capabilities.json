{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "conflictReporting": {
      "type": "boolean"
    },
    "exclusionPatterns": {
      "type": "boolean"
    },
    "modes": {
      "description": "an array of at least 1 item(s)",
      "items": {
        "enum": [
          "two-way-safe",
          "two-way-resolved",
          "one-way-safe",
          "one-way-replica"
        ],
        "type": "string"
      },
      "minItems": 1,
      "title": "minItems(1)",
      "type": "array"
    },
    "progressReporting": {
      "type": "boolean"
    },
    "remoteAgentDeployment": {
      "enum": [
        "auto",
        "preinstalled",
        "none"
      ],
      "type": "string"
    }
  },
  "required": [
    "modes",
    "remoteAgentDeployment",
    "exclusionPatterns",
    "conflictReporting",
    "progressReporting"
  ],
  "type": "object"
}
