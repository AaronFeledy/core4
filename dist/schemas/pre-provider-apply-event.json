{
  "$defs": {
    "DateTimeUtc": {
      "description": "a string to be decoded into a DateTime.Utc",
      "type": "string"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "_tag": {
      "enum": [
        "pre-provider-apply"
      ],
      "type": "string"
    },
    "app": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "user",
            "global",
            "scratch"
          ],
          "type": "string"
        },
        "root": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "root"
      ],
      "type": "object"
    },
    "providerId": {
      "type": "string"
    },
    "timestamp": {
      "$ref": "#/$defs/DateTimeUtc"
    }
  },
  "required": [
    "_tag",
    "app",
    "providerId",
    "timestamp"
  ],
  "type": "object"
}
