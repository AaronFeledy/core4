{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "id": {
      "description": "a string matching the pattern ^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "resolution": {
      "anyOf": [
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "enum": [
                "git"
              ],
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "url"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "checksum": {
              "type": "string"
            },
            "kind": {
              "enum": [
                "tarball"
              ],
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "url"
          ],
          "type": "object"
        }
      ]
    }
  },
  "required": [
    "resolution"
  ],
  "type": "object"
}
