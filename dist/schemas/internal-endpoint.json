{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "anyOf": [
    {
      "additionalProperties": false,
      "properties": {
        "_tag": {
          "description": "Discriminates a service-only endpoint.",
          "enum": [
            "internal"
          ],
          "type": "string"
        },
        "name": {
          "description": "Optional endpoint name.",
          "type": "string"
        },
        "port": {
          "description": "a number between 1 and 65535",
          "maximum": 65535,
          "minimum": 1,
          "title": "between(1, 65535)",
          "type": "integer"
        },
        "protocol": {
          "description": "Service-facing network protocol.",
          "enum": [
            "http",
            "https",
            "tcp",
            "udp"
          ],
          "type": "string"
        }
      },
      "required": [
        "_tag",
        "protocol",
        "port"
      ],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "_tag": {
          "description": "Discriminates a service-only endpoint.",
          "enum": [
            "internal"
          ],
          "type": "string"
        },
        "name": {
          "description": "Optional endpoint name.",
          "type": "string"
        },
        "protocol": {
          "description": "Unix-socket endpoint protocol.",
          "enum": [
            "unix"
          ],
          "type": "string"
        },
        "socketPath": {
          "type": "string"
        }
      },
      "required": [
        "_tag",
        "protocol",
        "socketPath"
      ],
      "type": "object"
    }
  ]
