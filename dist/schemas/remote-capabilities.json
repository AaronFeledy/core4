{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "auth": {
      "enum": [
        "none",
        "token",
        "oauth",
        "basic",
        "ssh",
        "custom"
      ],
      "type": "string"
    },
    "datasets": {
      "items": {
        "enum": [
          "database",
          "files",
          "config",
          "blob"
        ],
        "type": "string"
      },
      "type": "array"
    },
    "environments": {
      "type": "boolean"
    },
    "protectedByDefault": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "push": {
      "type": "boolean"
    },
    "tool": {
      "type": "string"
    }
  },
  "required": [
    "environments",
    "push",
    "datasets"
  ],
  "type": "object"
}
