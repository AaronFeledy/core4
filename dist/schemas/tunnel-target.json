{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "anyOf": [
    {
      "additionalProperties": false,
      "properties": {
        "_tag": {
          "enum": [
            "route"
          ],
          "type": "string"
        },
        "hostname": {
          "type": "string"
        },
        "routeId": {
          "description": "a string at least 1 character(s) long",
          "minLength": 1,
          "title": "minLength(1)",
          "type": "string"
        }
      },
      "required": [
        "_tag",
        "routeId"
      ],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "_tag": {
          "enum": [
            "service"
          ],
          "type": "string"
        },
        "port": {
          "description": "a number between 1 and 65535",
          "maximum": 65535,
          "minimum": 1,
          "title": "between(1, 65535)",
          "type": "integer"
        },
        "protocol": {
          "enum": [
            "http",
            "https",
            "tcp"
          ],
          "type": "string"
        },
        "service": {
          "type": "string"
        }
      },
      "required": [
        "_tag",
        "service",
        "port"
      ],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "_tag": {
          "enum": [
            "loopback"
          ],
          "type": "string"
        },
        "url": {
          "format": "uri",
          "pattern": "^https?:\\/\\/(?:localhost|127\\.0\\.0\\.1|\\[::1\\]):(?:[1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])(?:[/?#].*)?$",
          "type": "string"
        }
      },
      "required": [
        "_tag",
        "url"
      ],
      "type": "object"
    }
  ]
}
