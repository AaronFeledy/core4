{
  "$defs": {
    "DateTimeUtc": {
      "description": "a string to be decoded into a DateTime.Utc",
      "type": "string"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "_tag": {
      "enum": [
        "pre-dataset-fetch"
      ],
      "type": "string"
    },
    "dataset": {
      "enum": [
        "database",
        "files",
        "config",
        "blob"
      ],
      "type": "string"
    },
    "env": {
      "type": "string"
    },
    "eventName": {
      "enum": [
        "pre-dataset-fetch"
      ],
      "type": "string"
    },
    "remote": {
      "type": "string"
    },
    "timestamp": {
      "$ref": "#/$defs/DateTimeUtc"
    }
  },
  "required": [
    "_tag",
    "eventName",
    "remote",
    "env",
    "dataset",
    "timestamp"
  ],
  "type": "object"
}
