{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "_tag": {
      "enum": [
        "code.snippet"
      ],
      "type": "string"
    },
    "code": {
      "description": "Source code text to render.",
      "type": "string"
    },
    "highlightLines": {
      "description": "Optional 1-based line numbers to highlight.",
      "items": {
        "description": "a positive number",
        "exclusiveMinimum": 0,
        "title": "positive",
        "type": "integer"
      },
      "type": "array"
    },
    "language": {
      "description": "Optional tree-sitter language id; plain text when absent or unknown.",
      "type": "string"
    },
    "path": {
      "description": "Optional display-only origin path (already redacted by the publisher).",
      "type": "string"
    },
    "startLine": {
      "description": "Optional 1-based first line number for gutter numbering.",
      "exclusiveMinimum": 0,
      "title": "positive",
      "type": "integer"
    }
  },
  "required": [
    "_tag",
    "code"
  ],
  "type": "object"
}
