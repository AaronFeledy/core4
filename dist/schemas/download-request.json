{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "allowFileSource": {
      "type": "boolean"
    },
    "callerId": {
      "type": "string"
    },
    "destination": {
      "anyOf": [
        {
          "additionalProperties": false,
          "properties": {
            "directory": {
              "type": "string"
            },
            "filename": {
              "type": "string"
            },
            "kind": {
              "enum": [
                "file"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind",
            "directory",
            "filename"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "enum": [
                "memory"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        }
      ]
    },
    "expectedSha256": {
      "type": "string"
    },
    "expectedSizeBytes": {
      "type": "number"
    },
    "offline": {
      "type": "boolean"
    },
    "redactionTokens": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "url": {
      "type": "string"
    }
  },
  "required": [
    "url",
    "destination"
  ],
  "type": "object"
}
