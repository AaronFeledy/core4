{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "animation": {
      "description": "Continuous/live redraw supported (spinners, progress fill).",
      "type": "boolean"
    },
    "color": {
      "description": "ANSI color output supported.",
      "type": "boolean"
    },
    "interactive": {
      "description": "Keyboard input honored (task-tree focus/expand, prompts).",
      "type": "boolean"
    },
    "notifications": {
      "description": "Desktop-notification path supported (§8.9.7).",
      "type": "boolean"
    }
  },
  "required": [
    "color",
    "interactive",
    "animation",
    "notifications"
  ],
  "type": "object"
}
