{
  "$defs": {
    "DateTimeUtc": {
      "description": "a string to be decoded into a DateTime.Utc",
      "type": "string"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "_tag": {
      "enum": [
        "task.tree.complete"
      ],
      "type": "string"
    },
    "durationMs": {
      "type": "number"
    },
    "failed": {
      "type": "number"
    },
    "parentId": {
      "type": "string"
    },
    "succeeded": {
      "type": "number"
    },
    "summary": {
      "type": "string"
    },
    "timestamp": {
      "$ref": "#/$defs/DateTimeUtc"
    }
  },
  "required": [
    "_tag",
    "parentId",
    "succeeded",
    "failed",
    "timestamp"
  ],
  "type": "object"
}
