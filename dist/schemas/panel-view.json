{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "an array of at most 8 item(s)",
  "items": {
    "description": "an array of at most 32 item(s)",
    "items": {
      "additionalProperties": false,
      "properties": {
        "bold": {
          "description": "Bold weight when true.",
          "type": "boolean"
        },
        "dim": {
          "description": "Dim intensity when true.",
          "type": "boolean"
        },
        "italic": {
          "description": "Italic style when true.",
          "type": "boolean"
        },
        "text": {
          "description": "Span text content (UTF-8).",
          "type": "string"
        },
        "tone": {
          "description": "Semantic color tone (default muted accent success warning danger).",
          "enum": [
            "default",
            "muted",
            "accent",
            "success",
            "warning",
            "danger"
          ],
          "type": "string"
        },
        "underline": {
          "description": "Underline decoration when true.",
          "type": "boolean"
        }
      },
      "required": [
        "text"
      ],
      "type": "object"
    },
    "maxItems": 32,
    "title": "maxItems(32)",
    "type": "array"
  },
  "maxItems": 8,
  "title": "maxItems(8)",
  "type": "array"
}
