{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "anyOf": [
    {
      "additionalProperties": false,
      "properties": {
        "_tag": {
          "enum": [
            "code.snippet"
          ],
          "type": "string"
        },
        "code": {
          "description": "Source code text to render.",
          "type": "string"
        },
        "highlightLines": {
          "description": "Optional 1-based line numbers to highlight.",
          "items": {
            "description": "a positive number",
            "exclusiveMinimum": 0,
            "title": "positive",
            "type": "integer"
          },
          "type": "array"
        },
        "language": {
          "description": "Optional tree-sitter language id; plain text when absent or unknown.",
          "type": "string"
        },
        "path": {
          "description": "Optional display-only origin path (already redacted by the publisher).",
          "type": "string"
        },
        "startLine": {
          "description": "Optional 1-based first line number for gutter numbering.",
          "exclusiveMinimum": 0,
          "title": "positive",
          "type": "integer"
        }
      },
      "required": [
        "_tag",
        "code"
      ],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "_tag": {
          "enum": [
            "diff.render"
          ],
          "type": "string"
        },
        "language": {
          "description": "Optional language hint for future syntax-aware presentation.",
          "type": "string"
        },
        "path": {
          "description": "Optional display-only path for the diff.",
          "type": "string"
        },
        "unified": {
          "description": "Standard unified-diff text.",
          "type": "string"
        }
      },
      "required": [
        "_tag",
        "unified"
      ],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "_tag": {
          "enum": [
            "markdown.block"
          ],
          "type": "string"
        },
        "markdown": {
          "description": "Markdown source to render or pass through.",
          "type": "string"
        }
      },
      "required": [
        "_tag",
        "markdown"
      ],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "_tag": {
          "enum": [
            "notify.desktop"
          ],
          "type": "string"
        },
        "body": {
          "description": "Optional notification body (up to 4096 chars).",
          "maxLength": 4096,
          "title": "maxLength(4096)",
          "type": "string"
        },
        "title": {
          "description": "Notification title (1..256 chars after schema decode).",
          "maxLength": 256,
          "minLength": 1,
          "title": "maxLength(256)",
          "type": "string"
        },
        "urgency": {
          "description": "Optional urgency hint for presentation consumers.",
          "enum": [
            "info",
            "success",
            "failure"
          ],
          "type": "string"
        }
      },
      "required": [
        "_tag",
        "title"
      ],
      "type": "object"
    }
  ]
}
