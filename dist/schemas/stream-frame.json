{
  "$defs": {
    "DateTimeUtc": {
      "description": "a string to be decoded into a DateTime.Utc",
      "type": "string"
    },
    "DeprecationNotice": {
      "additionalProperties": false,
      "description": "A structured deprecation declaration attached to a public surface.",
      "properties": {
        "docsUrl": {
          "format": "uri",
          "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "removeIn": {
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
          "type": "string"
        },
        "replacement": {
          "type": "string"
        },
        "severity": {
          "enum": [
            "info",
            "warn",
            "error"
          ],
          "type": "string"
        },
        "since": {
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
          "type": "string"
        },
        "ticket": {
          "type": "string"
        }
      },
      "required": [
        "since",
        "note"
      ],
      "title": "Deprecation Notice",
      "type": "object"
    },
    "DeprecationUse": {
      "additionalProperties": false,
      "description": "A recorded runtime use of a deprecated public surface.",
      "properties": {
        "app": {
          "type": "string"
        },
        "callsite": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "command",
            "flag",
            "arg",
            "tooling-task",
            "recipe",
            "recipe-prompt",
            "landofile-key",
            "config-key",
            "env-override",
            "schema",
            "schema-field",
            "event",
            "event-field",
            "render-event",
            "service-type",
            "service-feature",
            "route-filter",
            "provider-extension",
            "manifest-field",
            "manifest-contribution",
            "plugin",
            "export",
            "tagged-error"
          ],
          "type": "string"
        },
        "notice": {
          "$ref": "#/$defs/DeprecationNotice"
        },
        "plugin": {
          "type": "string"
        },
        "timestamp": {
          "$ref": "#/$defs/DateTimeUtc"
        }
      },
      "required": [
        "kind",
        "id",
        "notice",
        "timestamp"
      ],
      "title": "Deprecation Use",
      "type": "object"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "anyOf": [
    {
      "additionalProperties": false,
      "properties": {
        "_tag": {
          "enum": [
            "stdout"
          ],
          "type": "string"
        },
        "chunk": {
          "type": "string"
        },
        "service": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      },
      "required": [
        "_tag",
        "chunk"
      ],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "_tag": {
          "enum": [
            "stderr"
          ],
          "type": "string"
        },
        "chunk": {
          "type": "string"
        },
        "service": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      },
      "required": [
        "_tag",
        "chunk"
      ],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "_tag": {
          "enum": [
            "event"
          ],
          "type": "string"
        },
        "event": {
          "type": "string"
        },
        "payload": {
          "$id": "/schemas/unknown",
          "title": "unknown"
        }
      },
      "required": [
        "_tag",
        "event",
        "payload"
      ],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "_tag": {
          "enum": [
            "result"
          ],
          "type": "string"
        },
        "envelope": {
          "additionalProperties": false,
          "properties": {
            "apiVersion": {
              "enum": [
                "v4"
              ],
              "type": "string"
            },
            "command": {
              "type": "string"
            },
            "deprecations": {
              "items": {
                "$ref": "#/$defs/DeprecationUse"
              },
              "type": "array"
            },
            "error": {
              "additionalProperties": false,
              "properties": {
                "_tag": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "remediation": {
                  "type": "string"
                }
              },
              "required": [
                "_tag",
                "message"
              ],
              "type": "object"
            },
            "ok": {
              "type": "boolean"
            },
            "result": {
              "$id": "/schemas/unknown",
              "title": "unknown"
            },
            "warnings": {
              "items": {
                "additionalProperties": false,
                "properties": {
                  "code": {
                    "type": "string"
                  },
                  "context": {
                    "additionalProperties": {
                      "type": "string"
                    },
                    "description": "Structured string metadata that identifies the warning source and affected input.",
                    "properties": {},
                    "required": [],
                    "type": "object"
                  },
                  "message": {
                    "type": "string"
                  },
                  "remediation": {
                    "type": "string"
                  }
                },
                "required": [
                  "code",
                  "message"
                ],
                "type": "object"
              },
              "type": "array"
            }
          },
          "required": [
            "apiVersion",
            "command",
            "ok",
            "warnings",
            "deprecations"
          ],
          "type": "object"
        }
      },
      "required": [
        "_tag",
        "envelope"
      ],
      "type": "object"
    }
  ]
}
