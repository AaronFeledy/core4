    "DeprecationNotice": {
      "additionalProperties": false,
      "description": "A structured deprecation declaration attached to a public surface.",
      "properties": {
        "docsUrl": {
          "format": "uri",
          "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://",
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "removeIn": {
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
          "type": "string"
        },
        "replacement": {
          "type": "string"
        },
        "severity": {
          "enum": [
            "info",
            "warn",
            "error"
          ],
          "type": "string"
        },
        "since": {
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
          "type": "string"
        },
        "ticket": {
          "type": "string"
        }
      },
      "required": [
        "since",
        "note"
      ],
      "title": "Deprecation Notice",
      "type": "object"
    }
  },
