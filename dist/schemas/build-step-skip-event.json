{
  "$defs": {
    "DateTimeUtc": {
      "description": "a string to be decoded into a DateTime.Utc",
      "type": "string"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "_tag": {
      "enum": [
        "build-step-skip"
      ],
      "type": "string"
    },
    "appRef": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "scratch",
            "user"
          ],
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id"
      ],
      "type": "object"
    },
    "buildKey": {
      "type": "string"
    },
    "cached": {
      "type": "boolean"
    },
    "eventName": {
      "enum": [
        "build-step-skip"
      ],
      "type": "string"
    },
    "phase": {
      "enum": [
        "artifact",
        "app"
      ],
      "type": "string"
    },
    "providerId": {
      "type": "string"
    },
    "reason": {
      "enum": [
        "up-to-date",
        "phase-aborted"
      ],
      "type": "string"
    },
    "serviceName": {
      "type": "string"
    },
    "timestamp": {
      "$ref": "#/$defs/DateTimeUtc"
    }
  },
  "required": [
    "_tag",
    "eventName",
    "appRef",
    "serviceName",
    "providerId",
    "phase",
    "buildKey",
    "cached",
    "reason",
    "timestamp"
  ],
  "type": "object"
}
