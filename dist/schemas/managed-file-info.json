{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "mode": {
      "enum": [
        "file",
        "block",
        "keys"
      ],
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "state": {
      "enum": [
        "managed",
        "adopted",
        "conflict",
        "missing",
        "drifted"
      ],
      "type": "string"
    }
  },
  "required": [
    "path",
    "owner",
    "mode",
    "state"
  ],
  "type": "object"
}
