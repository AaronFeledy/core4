{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "store": {
      "additionalProperties": false,
      "properties": {
        "app": {
          "type": "string"
        },
        "scope": {
          "enum": [
            "service",
            "app",
            "global"
          ],
          "type": "string"
        },
        "store": {
          "type": "string"
        }
      },
      "required": [
        "app",
        "store"
      ],
      "type": "object"
    }
  },
  "required": [
    "id",
    "store"
  ],
  "type": "object"
}
