{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "app": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "user",
            "global",
            "scratch"
          ],
          "type": "string"
        },
        "root": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "root"
      ],
      "type": "object"
    },
    "excludes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "mode": {
      "enum": [
        "two-way-safe",
        "two-way-resolved",
        "one-way-safe",
        "one-way-replica"
      ],
      "type": "string"
    },
    "mountKey": {
      "type": "string"
    },
    "permissions": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        }
      },
      "required": [],
      "type": "object"
    },
    "service": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "target": {
      "anyOf": [
        {
          "additionalProperties": false,
          "properties": {
            "_tag": {
              "enum": [
                "volume"
              ],
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "path": {
              "type": "string"
            }
          },
          "required": [
            "_tag",
            "name",
            "path"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "_tag": {
              "enum": [
                "service"
              ],
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "service": {
              "type": "string"
            }
          },
          "required": [
            "_tag",
            "service",
            "path"
          ],
          "type": "object"
        }
      ]
    }
  },
  "required": [
    "app",
    "service",
    "mountKey",
    "source",
    "target",
    "mode",
    "excludes"
  ],
  "type": "object"
}
