{
  "$defs": {
    "DateTimeUtc": {
      "description": "a string to be decoded into a DateTime.Utc",
      "type": "string"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "_tag": {
      "enum": [
        "task.detail"
      ],
      "type": "string"
    },
    "line": {
      "type": "string"
    },
    "stream": {
      "enum": [
        "stdout",
        "stderr"
      ],
      "type": "string"
    },
    "taskId": {
      "type": "string"
    },
    "timestamp": {
      "$ref": "#/$defs/DateTimeUtc"
    }
  },
  "required": [
    "_tag",
    "taskId",
    "stream",
    "line",
    "timestamp"
  ],
  "type": "object"
}
