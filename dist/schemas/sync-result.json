                "type": "string"
              },
              "app": {
                "type": "string"
              },
              "store": {
                "type": "string"
              }
            },
            "required": [
              "_tag",
              "app",
              "store"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "_tag": {
                "enum": [
                  "servicePath"
                ],
                "type": "string"
              },
              "app": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "service": {
                "type": "string"
              }
            },
            "required": [
              "_tag",
              "app",
              "service",
              "path"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "_tag": {
                "enum": [
                  "serviceCmd"
