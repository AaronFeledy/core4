              },
              "service": {
                "type": "string"
              }
            },
            "required": [
              "_tag",
              "app",
              "service",
              "command"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "_tag": {
                "enum": [
                  "artifact"
