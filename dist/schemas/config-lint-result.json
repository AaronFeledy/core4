{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "app": {
      "type": "string"
    },
    "file": {
      "type": "string"
    },
    "valid": {
      "type": "boolean"
    },
    "violations": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "column": {
            "type": "number"
          },
          "line": {
            "type": "number"
          },
          "message": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "suggestedFix": {
            "type": "string"
          }
        },
        "required": [
          "path",
          "message"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "app",
    "file",
    "valid",
    "violations"
  ],
  "type": "object"
}
