{
  "$defs": {
    "DateTimeUtc": {
      "description": "a string to be decoded into a DateTime.Utc",
      "type": "string"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "createdAt": {
      "$ref": "#/$defs/DateTimeUtc"
    },
    "labels": {
      "additionalProperties": {
        "type": "string"
      },
      "properties": {},
      "required": [],
      "type": "object"
    },
    "ref": {
      "additionalProperties": false,
      "properties": {
        "app": {
          "type": "string"
        },
        "scope": {
          "enum": [
            "service",
            "app",
            "global"
          ],
          "type": "string"
        },
        "store": {
          "type": "string"
        }
      },
      "required": [
        "app",
        "store"
      ],
      "type": "object"
    },
    "sizeBytes": {
      "type": "number"
    }
  },
  "required": [
    "ref"
  ],
  "type": "object"
}
