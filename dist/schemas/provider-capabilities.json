{
  "$defs": {
    "HostProxyContainerTarget": {
      "anyOf": [
        {
          "additionalProperties": false,
          "properties": {
            "arch": {
              "description": "x64 container CPU architecture.",
              "enum": [
                "x64"
              ],
              "type": "string"
            },
            "os": {
              "description": "Container operating system.",
              "enum": [
                "linux"
              ],
              "type": "string"
            }
          },
          "required": [
            "os",
            "arch"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "arch": {
              "description": "arm64 container CPU architecture.",
              "enum": [
                "arm64"
              ],
              "type": "string"
            },
            "os": {
              "description": "Container operating system.",
              "enum": [
                "linux"
              ],
              "type": "string"
            }
          },
          "required": [
            "os",
            "arch"
          ],
          "type": "object"
        }
      ],
      "description": "Linux container architecture eligible for the host-proxy shim.",
      "title": "Host Proxy Container Target"
    },
    "HostProxyGatewayHostname": {
      "description": "Provider DNS hostname that Linux containers use to reach the host TCP gateway.",
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9.-]*[A-Za-z0-9])?$",
      "title": "Host Proxy Gateway Hostname",
      "type": "string"
    },
    "HostProxyProviderCapabilities": {
      "additionalProperties": false,
      "description": "Structured host-proxy transport capabilities declared by a runtime provider.",
      "properties": {
        "containerTargets": {
          "description": "Linux container targets the provider can run for host-proxy shim dispatch.",
          "items": {
            "$ref": "#/$defs/HostProxyContainerTarget"
          },
          "title": "Host Proxy Container Targets",
          "type": "array"
        },
        "tcpHostGateway": {
          "allOf": [
            {
              "$ref": "#/$defs/HostProxyGatewayHostname"
            }
          ],
          "description": "Provider DNS hostname used for host-proxy TCP host-gateway transport.",
          "title": "Host Proxy TCP Host Gateway"
        }
      },
      "required": [
        "containerTargets"
      ],
      "title": "Host Proxy Provider Capabilities",
      "type": "object"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "artifactBuild": {
      "type": "boolean"
    },
    "artifactExport": {
      "type": "boolean"
    },
    "artifactImport": {
      "type": "boolean"
    },
    "artifactPull": {
      "type": "boolean"
    },
    "bindMountPerformance": {
      "enum": [
        "native",
        "slow",
        "none"
      ],
      "type": "string"
    },
    "bindMounts": {
      "type": "boolean"
    },
    "buildSecrets": {
      "type": "boolean"
    },
    "buildSsh": {
      "type": "boolean"
    },
    "composeSpec": {
      "enum": [
        "none",
        "portable",
        "native"
      ],
      "type": "string"
    },
    "copyMounts": {
      "type": "boolean"
    },
    "copyOnWriteAppRoot": {
      "type": "boolean"
    },
    "ephemeralMounts": {
      "type": "boolean"
    },
    "hostPortPublish": {
      "enum": [
        "native",
        "proxy",
        "manual",
        "none"
      ],
      "type": "string"
    },
    "hostProxy": {
      "allOf": [
        {
          "$ref": "#/$defs/HostProxyProviderCapabilities"
        }
      ],
      "description": "Structured provider-declared host-proxy transport capabilities.",
      "title": "Host Proxy"
    },
    "hostReachability": {
      "enum": [
        "native",
        "emulated",
        "none"
      ],
      "type": "string"
    },
    "multiServiceApply": {
      "type": "boolean"
    },
    "persistentStorage": {
      "type": "boolean"
    },
    "privilegedServices": {
      "type": "boolean"
    },
    "providerExtensions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "rootless": {
      "type": "boolean"
    },
    "routeProvider": {
      "type": "boolean"
    },
    "serviceExec": {
      "type": "boolean"
    },
    "serviceFileCopy": {
      "enum": [
        "native",
        "exec",
        "none"
      ],
      "type": "string"
    },
    "serviceHealth": {
      "enum": [
        "native",
        "lando",
        "none"
      ],
      "type": "string"
    },
    "serviceLogs": {
      "type": "boolean"
    },
    "serviceLogSources": {
      "type": "boolean"
    },
    "sharedCrossAppNetwork": {
      "type": "boolean"
    },
    "tlsCertificates": {
      "enum": [
        "native",
        "lando",
        "none"
      ],
      "type": "string"
    },
    "volumeSnapshot": {
      "enum": [
        "native",
        "copy",
        "none"
      ],
      "type": "string"
    }
  },
  "required": [
    "artifactBuild",
    "artifactPull",
    "buildSecrets",
    "buildSsh",
    "multiServiceApply",
    "serviceExec",
    "serviceLogs",
    "serviceLogSources",
    "serviceHealth",
    "hostReachability",
    "sharedCrossAppNetwork",
    "persistentStorage",
    "bindMounts",
    "bindMountPerformance",
    "copyMounts",
    "copyOnWriteAppRoot",
    "volumeSnapshot",
    "serviceFileCopy",
    "artifactExport",
    "artifactImport",
    "ephemeralMounts",
    "hostPortPublish",
    "routeProvider",
    "tlsCertificates",
    "rootless",
    "privilegedServices",
    "composeSpec",
    "providerExtensions"
  ],
  "type": "object"
}
